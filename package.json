{
  "name": "@barrys27/ui",
  "version": "1.3.3",
  "description": "A minimalist, 8-point grid UI architecture inspired by iOS HIG.",
  "main": "static/css/main.css",
  "style": "static/css/main.css",
  "sass": "src/scss/main.scss",
  "exports": {
    ".": {
      "sass": "./src/scss/main.scss",
      "import": "./static/css/main.css",
      "require": "./static/css/main.css",
      "default": "./static/css/main.css"
    },
    "./css": "./static/css/main.css",
    "./scss/*": "./src/scss/*.scss"
  },
  "files": [
    "src/scss",
    "static/css",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build":          "sass --style=compressed src/scss:static/css",
    "watch":          "sass --watch src/scss:static/css",
    "build:stroma":   "tsup src/js/stroma.js --format esm,cjs --dts --minify --clean --out-dir dist/stroma",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "css",
    "scss",
    "ui-kit",
    "design-system",
    "minimalist",
    "ios-inspired",
    "8-point-grid"
  ],
  "author": "Bairu Song",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/asong56/acdn.git"
  },
  "devDependencies": {
    "sass": "^1.97.3",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
